# Frontend Environment Variables

# --- Option 1: Supabase (default, already provisioned) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- Option 2: Express + MongoDB backend (optional) ---
# Set VITE_API_BASE_URL to your deployed Express API URL to switch
# the frontend from Supabase to the MongoDB backend.
# VITE_API_BASE_URL=http://localhost:5000
